# Copy to career_agent_platform/.env (or repo-root .env if you load from there).
# Never commit real credentials.

# LinkedIn (future browser automation — not used in current release)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# LLM provider (future resume tailoring / outreach — scaffold only)
OPENAI_API_KEY=

# Playwright browser binary path (optional; future browser layer)
PLAYWRIGHT_BROWSER_PATH=

# Optional: raise ops log verbosity (default INFO)
# CAREER_AGENT_LOG_LEVEL=DEBUG

# Reviewer-safe read-only mode (no review queue / resume / package writes)
# CAREER_AGENT_DEMO_MODE=1

# Optional: emit benchmark_signature in governance panel / ops logs
# CAREER_AGENT_BENCHMARK_SIGNALS=1

# Setup guide: docs/DEVELOPER.md
# Public demo data: career_agent_platform/demo/public/
